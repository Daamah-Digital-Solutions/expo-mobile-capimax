{
  "expo": {
    "name": "Capimax Assets",
    "slug": "capimax-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "capimax",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#121c30",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.capimax.mobile"
    },
    "android": {
      "package": "com.capimax.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121c30"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#121c30",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#121c30"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.456574106712-m6f6jb6r50s3vb9mb0ks3jsvv579gua2"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiUrl": "https://api.capimaxinvestment.com/",
      "chatUrl": "https://ai.capimaxgroup.com/webhook/capimax-assets/chat",
      "paypalClientId": "AZHEGDb90rDEPUTjBV5cssSfewEAQrwG8cMy0W6NUdj8hLk_XPedJ_hhsJ0m9AG07AfsbBMbkTKhtwyw",
      "paypalEnv": "live",
      "paypalCurrency": "USD",
      "webOrigin": "https://capimaxinvestment.com",
      "google": {
        "webClientId": "456574106712-12r77cu6ft5jsmqfom0dcsom8bv6au4d.apps.googleusercontent.com",
        "iosClientId": "456574106712-m6f6jb6r50s3vb9mb0ks3jsvv579gua2.apps.googleusercontent.com"
      },
      "router": {},
      "eas": {
        "projectId": "ae11d47a-8298-4c40-ac6e-c1855431e08b"
      }
    }
  }
}
